# Вы можете расположить сценарий своей игры в этом файле.

# 1. Сначала данные (лор)
init python:
    lore_data = {
        "ran": ("Ран", "Описание...", "images/characters/arlin.png"),
        "glairo": ("Глайро", "Описание...", "images/characters/arlin.png"),
        "shadow": ("Тень", "Описание...", "images/characters/arlin.png")
    }

# 2. Потом дефолтные переменные
default persistent.unlocked_entities = set()
default current_lore = None

# Определение персонажей игры.
define a = Character('Арлин', color="#c8ffc8")
define r = Character("Ран", color="#5cd6d6")
define g = Character("Глайро", color="#ffcc66")
define i = Character("Инквизитор", color="#ffffff")
define s = Character("Сераи", color="#bc8f8f")
define n = Character(None, kind=nvl, what_xalign=0.5, what_text_align=0.5) # Для длинных текстов про Лор игры

default glairo_trust = 0
default essence_absorbed = False # Способ, которым Ран достал сущность

# Вместо использования оператора image можете просто
# складывать все ваши файлы изображений в папку images.
# Например, сцену bg room можно вызвать файлом "bg room.png",
# а eileen happy — "eileen happy.webp", и тогда они появятся в игре.

# Игра начинается здесь:
label start:

    stop music fadeout 2.0
    scene nvl_bg

    # Переход к кошмару
    n "Ты слышишь их, маленький мост? Слышишь, как они захлебываются в твоей «свободе»?"
    n "Проснись, ошибка творца. Твой мир уже горит, а ты спишь в его углях."

    with hpunch


    nvl clear

    # --- РЕАЛЬНОСТЬ ---
    scene bg_scene
    play sound "audio/rain_and_wind.ogg" # Замени на свой файл

    show arlin
    
    "Резкий вдох. Сознание возвращается вместе с болью."
    "Холодная грязь забивается в рот, а дождь со снегом нещадно бьет по лицу."

    $ persistent.unlocked_entities.add("ran")
    $ renpy.notify("Запись добавлена: Ран")
    r "А-ах!.. Кха... черт..."

    "Ран лежит на дне оврага под крутым склоном. Нога ноет от падения."
    "Над ним, на скалистом выступе, виднеется перекошенная стальная дверь — вход в заброшенную лабораторию отца."

    r "Опять... Опять они. Даже в отключке не дают покоя."
    r "Нужно подниматься. Я шел сюда не для того, чтобы сдохнуть в канаве."

    # Сцена внутри лаборатории
    scene bg_lab: 
        xysize (1920, 1080) 
    with fade
    stop sound fadeout 1.0
    
    "Ран с трудом раздвигает створки. Внутри пахнет озоном и старой бумагой. Гробовая тишина давит на уши."
    
    r "Отец? Ты здесь?.."
    
    "Ответа нет. Ран проходит в центр зала, где в стеклянной капсуле пульсирует синим светом крошечная сущность."

    # Появление Глайро
    show glairo_silhouette at right with dissolve
    
    "???" "Сделай еще шаг, и я узнаю, какой объем крови может потерять человек за пять секунд."

    r "Кто здесь?! Ищейка Инквизиции?"

    show glairo_normal at right with dissolve
    $ persistent.unlocked_entities.add("glairo")
    $ renpy.notify("Запись добавлена: Глайро")
    
    g "Слишком много чести для них. Я Глайро. И я здесь единственный, кто понимает, что мы стоим на куче нестабильного праха."

    r "Что тебе нужно от этого места?"

    g "Ответы. У меня в памяти дыра размером с это королевство. А ты... ты похож на ключ к ним."
    
    play sound "audio/distant_horn.ogg" # Звук рога инквизиции
    
    g "Слышишь? Твои преследователи уже в овраге. У нас есть минуты три."

    r "Три минуты? Тогда помоги мне открыть эту чертову колбу!"

    # --- ВЫБОР ---
    g "Есть два пути. Я могу взломать пульт через дневник — это надежно, но будет много шума."
    g "Или ты можешь рискнуть и приложить руку. Если ты сын профессора, система может узнать тебя. Если нет — тебя испепелит."

    menu:
        "Довериться логике Глайро (Взломать пульт)":
            $ glairo_trust += 1
            jump path_logic

        "Довериться чувствам (Приложить руку)":
            $ essence_absorbed = True
            jump path_instinct

label path_logic:
    "Глайро кидается к терминалу. Слышен треск электричества."
    play sound "audio/electric_spark.ogg"
    with hpunch
    
    "Сирена оглушает Рана. Стеклянный купол с лязгом поднимается."
    r "Ты сказал 'шумно', а не 'поднять на уши всё королевство'!"
    g "Зато твои пальцы на месте. Хватай её и бежим!"
    jump combat_setup

label path_instinct:
    "Ран делает шаг к капсуле. Он чувствует, как сущность внутри дрожит."
    r "Она боится взлома... Я попробую сам."
    
    "Ран кладет ладонь на стекло. Вены на его руке вспыхивают бирюзовым."
    "Стекло капсулы тает, как лед. Энергия мягко перетекает в Рана, оседая свечением на запястье."
    
    g "Невероятно... Прямой резонанс. Ты действительно его сын."
    jump combat_setup

label combat_setup:
    play sound "audio/door_crash.ogg"
    with vpunch
    
    i "ВОТ ОНИ! СХВАТИТЬ ЕРЕТИКОВ!"
    
    "В дверях появляются фигуры в тяжелых плащах. Глайро выхватывает нож."
    
    g "Ну вот и всё. Время для разговоров закончилось."
    
    r "Я чувствую её силу... Глайро, прикрой меня!"

    "Свет в лаборатории гаснет, сменяясь яростным блеском стали и магическим сиянием."
    
    # Здесь можно добавить переход к следующей главе или конец демо-версии
    "КОНЕЦ ПЕРВОГО ЭПИЗОДА"

    return